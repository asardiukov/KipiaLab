# 1. Берем готовый образ Nginx на базе крошечного Alpine Linux
FROM nginx:alpine

# 2. Копируем все файлы твоего проекта KipLab (HTML, JS, CSS)
# в ту папку, откуда Nginx по умолчанию раздает сайты
COPY . /usr/share/nginx/html

# 3. Говорим, что контейнер будет отдавать трафик по стандартному 80 порту
EXPOSE 80
